-- Replace <ADMIN_EMAIL> with the real administrator email before running.
-- This is the one-time recovery step for the current lockout.

update public.salespeople
set permissions = '{
  "orders": true,
  "clients": true,
  "products": true,
  "companies": true,
  "team": true,
  "settings": true
}'::jsonb,
is_admin = true
where lower(email) = lower('<ADMIN_EMAIL>');
